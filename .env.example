# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — your client secret must never be committed.

# --- SoundCloud app credentials (from https://soundcloud.com/you/apps) ---
SC_CLIENT_ID=your-client-id
SC_CLIENT_SECRET=your-client-secret

# Must EXACTLY match the redirect URI registered on the app
SC_REDIRECT_URI=https://www.jpcarrascal.com/music-cicd/redirect

# --- Watch settings (needed for the `watch` command) ---
# Folder to watch for finished mixes
SC_WATCH_DIR=/absolute/path/to/your/Mixes

# Playlist to add uploads to. Run `python music_cicd.py playlists` to find the id.
# Leave empty to upload without adding to a playlist.
SC_PLAYLIST_ID=

# --- Optional tuning ---
# SC_EXTENSIONS=wav,aiff,flac,mp3
# SC_POLL_SECONDS=5
# SC_SETTLE_SECONDS=10
